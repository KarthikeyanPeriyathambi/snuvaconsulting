# Example .env configurations for Ollama

# === LOCAL OLLAMA SETUP ===
# Run Ollama locally on your machine
LLM_PROVIDER=ollama
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=minimax-m2.5:cloud
# OLLAMA_API_KEY= (not needed for local)

# === API-BASED OLLAMA SETUP ===
# Use cloud-based Ollama service
# LLM_PROVIDER=ollama
# OLLAMA_API_URL=https://api.ollama.com/v1/chat
# OLLAMA_MODEL=minimax-m2.5:cloud
# OLLAMA_API_KEY=ec510a699fd3498ca3f02b070ecf5c3b.0BOL_C1a7xcz9O58Z7FdI968

# === GEMINI SETUP (Alternative) ===
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here